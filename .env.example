# =============================================================================
# directors-bot-v1 環境変数テンプレート
# =============================================================================
# このファイルをコピーして `.env.local` を作り、実値を書き込む。

# -----------------------------------------------------------------------------
# Gemini (Google AI Studio) - 修正エージェント用
# -----------------------------------------------------------------------------
# https://aistudio.google.com/apikey でキーを作成
GEMINI_API_KEY=
# Flash 系 (速度・コスト重視)。高精度が必要なら gemini-3.1-pro-preview に差し替え。
# さらに安く軽くしたい場合は gemini-3.1-flash-lite-preview。preview モデルは更新されるので注意。
GEMINI_MODEL=gemini-3-flash-preview
# 全体指示モード用モデル (省略時は GEMINI_MODEL を流用)。
# 全体デザイン変更には精度優先の pro を使うと iteration が減り結果的に速い。
GEMINI_GLOBAL_MODEL=gemini-3-pro-preview
# エージェントループの最大反復回数
GEMINI_MAX_ITERATIONS=120
# 個別 bash ツール実行のタイムアウト (秒)。30 分まで
AGENT_TIMEOUT_SEC=1800

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
BOT_GIT_AUTHOR_NAME=propagate-webcreation
BOT_GIT_AUTHOR_EMAIL=webcreation@propagateinc.com
GIT_DEPLOY_BRANCH=main

# -----------------------------------------------------------------------------
# Google Sheets
# -----------------------------------------------------------------------------
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=メイン
# ローカル開発: JSON ファイルパス (リポジトリにはコミットしない)
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-credentials.json
# Vercel など本番環境: Service Account JSON の中身をそのまま 1 行で貼り付け。
# JSON を優先、未設定時のみ PATH を使用する。
# 例: {"type":"service_account","client_email":"...","private_key":"-----BEGIN ...\n...\n-----END ...\n",...}
GOOGLE_SHEETS_CREDENTIALS_JSON=

# -----------------------------------------------------------------------------
# スプレッドシート ステータス値
# -----------------------------------------------------------------------------
SPREADSHEET_DONE_STATUS=デモサイト制作完了

# -----------------------------------------------------------------------------
# Vercel Sandbox
# -----------------------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
# ローカル動作時のみ `vercel env pull` で取得
VERCEL_OIDC_TOKEN=

# -----------------------------------------------------------------------------
# Supabase (ログイン/セッション)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# UI / ローカル動作
# -----------------------------------------------------------------------------
DEFAULT_PREVIEW_URL=
SESSION_DEFAULT_TTL_SEC=7200
